#!/usr/bin/env node
/**
 * SuperLocalMemory V3 - NPM CLI wrapper.
 *
 * Executes only the Python interpreter installed into this npm package's
 * private virtual environment. The Python runtime owns canonical data-root
 * precedence (SLM_DATA_DIR, SL_MEMORY_PATH, SLM_HOME); this wrapper passes the
 * environment through and performs no durable-data writes.
 *
 * Copyright (c) 2026 Varun Pratap Bhardwaj / Qualixar
 * Licensed under AGPL-3.0-or-later.
 */

'use strict';

const { spawnSync } = require('child_process');
const path = require('path');
const os = require('os');
const fs = require('fs');

const packageRoot = path.resolve(__dirname, '..');
const runtimePython = os.platform() === 'win32'
  ? path.join(packageRoot, '.slm-venv', 'Scripts', 'python.exe')
  : path.join(packageRoot, '.slm-venv', 'bin', 'python');

if (!fs.existsSync(runtimePython)) {
  console.error('SuperLocalMemory npm runtime is missing or incomplete.');
  console.error(`Expected the package-owned interpreter at: ${runtimePython}`);
  console.error('Repair it without touching system Python by running:');
  console.error('  npm rebuild superlocalmemory');
  console.error('If Python is missing, install Python 3.11-3.14 first.');
  process.exit(1);
}

const runtimeEnv = {
  ...process.env,
  PYTORCH_MPS_HIGH_WATERMARK_RATIO: '0.0',
  PYTORCH_MPS_MEM_LIMIT: '0',
  PYTORCH_ENABLE_MPS_FALLBACK: '1',
  TOKENIZERS_PARALLELISM: 'false',
  TORCH_DEVICE: 'cpu',
  CUDA_VISIBLE_DEVICES: '',
};
// Never let a caller's development checkout override the npm artifact.
delete runtimeEnv.PYTHONPATH;

const result = spawnSync(
  runtimePython,
  ['-m', 'superlocalmemory.cli.main', ...process.argv.slice(2)],
  { stdio: 'inherit', env: runtimeEnv },
);

if (result.error) {
  console.error(`SuperLocalMemory runtime failed to start: ${result.error.message}`);
  process.exit(1);
}
process.exit(Number.isInteger(result.status) ? result.status : 1);
